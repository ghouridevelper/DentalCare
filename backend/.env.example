# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB (local or MongoDB Atlas free tier)
MONGO_URI=mongodb://127.0.0.1:27017/clinic-booking

# Auth
JWT_SECRET=clinic-booking-demo-secret
JWT_EXPIRES_IN=7d

# Zapier — OUTGOING webhook (Zapier "Catch Hook" trigger URL)
# Fires the instant "booking confirmed" WhatsApp message the moment a patient books.
ZAPIER_CONFIRMATION_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/xxxxx/

# Shared secret Zapier must send back on INCOMING requests (reminder polling + mark-sent)
ZAPIER_SHARED_SECRET=change_this_shared_secret

# Admin seed user (created by npm run seed)
SEED_ADMIN_EMAIL=owner@clinic.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Clinic Owner
